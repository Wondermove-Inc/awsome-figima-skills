{
  "name": "figma-mcp-express-plugin",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch --mode development\" \"vite build --watch --mode development -c vite.config.main.ts\"",
    "build": "vite build && vite build -c vite.config.main.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint . --max-warnings 0"
  },
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "^1.0.0",
    "@figma/plugin-typings": "^1",
    "@sveltejs/vite-plugin-svelte": "^5",
    "concurrently": "^9",
    "eslint": "^10.5.0",
    "svelte": "^5",
    "typescript": "^5",
    "typescript-eslint": "^8.61.0",
    "vite": "^6",
    "vite-plugin-singlefile": "^2"
  }
}
